rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Together Sessions ─────────────────────────────────────────
    match /together_sessions/{sessionId} {
      // Anyone authenticated (including anonymous) can read sessions
      allow read: if request.auth != null;
      // Only authenticated users can create sessions (must be the owner)
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      // BUG-Q02 FIX: was 'any authenticated user can update', meaning any
      // user who knew the session ID could overwrite streamUrl, ownerId, etc.
      // Now: owner has full update access; guests may ONLY update member
      // presence/join fields and cannot touch playback control fields.
      allow update: if request.auth != null && (
        // Owner can update any field
        resource.data.ownerId == request.auth.uid
        ||
        // Guests may only touch join/presence fields — not playback controls
        (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['streamUrl', 'ownerId', 'songId', 'positionMs', 'isPlaying',
                     'previewDurationMs', 'videoId', 'videoPositionMs'])
        )
      );
      // Only owner can delete (when ending the session)
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
      // ── Chat Messages sub-collection ───────────────────────────
      match /chat_messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && resource.data.uid == request.auth.uid;
        allow update: if false;
      }
      // ── Game Rooms sub-collection ─────────────────────────────
      // FIX: was missing entirely → caused PERMISSION_DENIED for game rooms.
      // Security via the random sessionId in the path (only members who know
      // the 6-char session code can ever reach this collection).
      match /game_rooms/{roomId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null;
      }
      // ── Game Invites sub-collection ───────────────────────────
      // FIX: was missing entirely → caused PERMISSION_DENIED for game invites.
      match /game_invites/{inviteId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null;
      }
    }
  }
}
