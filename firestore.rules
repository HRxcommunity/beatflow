rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Together Sessions ─────────────────────────────────────────
    match /together_sessions/{sessionId} {

      // Anyone authenticated (including anonymous) can read sessions
      allow read: if request.auth != null;

      // Only authenticated users can create sessions (must be the owner)
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Any authenticated MEMBER of the session can update it.
      // BUG-015 FIX: old rule was `request.auth != null` (any authenticated user
      // could corrupt any session). Fix: only owner OR existing members may update.
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.ownerId
                        || request.auth.uid in resource.data.members.map(m, m.uid));

      // Only owner can delete (when ending the session)
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      // ── Chat Messages sub-collection ───────────────────────────
      match /chat_messages/{messageId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      // ── Game Rooms sub-collection ─────────────────────────────
      // BUG-G04 FIX: old rule allowed ANY authenticated user to read/write
      // game rooms. Now restricted to session members only, mirroring the
      // parent session's membership check.
      match /game_rooms/{roomId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/together_sessions/$(sessionId)).data.ownerId
              || request.auth.uid in get(/databases/$(database)/documents/together_sessions/$(sessionId)).data.members.map(m, m.uid));
      }

      // ── Game Invites sub-collection ───────────────────────────
      // BUG-G04 FIX: same membership restriction applied to game invites.
      match /game_invites/{inviteId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/together_sessions/$(sessionId)).data.ownerId
              || request.auth.uid in get(/databases/$(database)/documents/together_sessions/$(sessionId)).data.members.map(m, m.uid));
      }
    }
  }
}
